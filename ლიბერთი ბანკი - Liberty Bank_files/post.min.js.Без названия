app.controller('moneyTransferRateCalculatorController', ['$scope', function ($scope) {
    var _this = this;
    _this.$scope = $scope;
    $scope._this = _this;

    var _ratesMap = {};

    _this.data = {
        fromCurrencies: [],
        fromCurrency: null,
        toCurrencies: [],
        toCurrency: null,
        amount: 100
    };

    _this.init = function () {
        var rates = window._rates || [];
        var allowedFrom = window._mtRateFromCurrencies || [];
        var allowedTo = window._mtRateToCurrencies || [];

        _ratesMap = {};
        for (var i = 0; i < rates.length; i++) {
            _ratesMap[rates[i].Currency] = rates[i];
        }

        _this.data.fromCurrencies = allowedFrom.map(function (c) {
            return { id: c.id, title: c.title };
        });

        if (_this.data.fromCurrencies.length > 0) {
            _this.data.fromCurrency = _this.data.fromCurrencies[0];
        }

        _this.data.toCurrencies = allowedTo.length > 0
            ? allowedTo
            : [{ id: 'GEL', title: 'GEL' }];

        if (_this.data.toCurrencies.length > 0) {
            _this.data.toCurrency = _this.data.toCurrencies[0];
        }
    };

    function getAmount() {
        var val = parseFloat(_this.data.amount);
        return isNaN(val) || val <= 0 ? null : val;
    }

    function getRate() {
        if (!_this.data.fromCurrency || !_this.data.fromCurrency.id) return null;
        return _ratesMap[_this.data.fromCurrency.id] || null;
    }

    _this.hasResults = function () {
        return getAmount() != null && getRate() != null;
    };

    _this.getStandardAmount = function () {
        var a = getAmount(), r = getRate();
        if (!a || !r) return null;
        return (a * r.CommercialSell).toFixed(2);
    };

    _this.getMtAmount = function () {
        var a = getAmount(), r = getRate();
        if (!a || !r) return null;
        return (a * r.MTRateBuy).toFixed(2);
    };

    _this.getProfit = function () {
        var std = parseFloat(_this.getStandardAmount());
        var mt = parseFloat(_this.getMtAmount());
        if (isNaN(std) || isNaN(mt)) return null;
        return (mt - std).toFixed(2);
    };

    _this.isProfitPositive = function () {
        var profit = parseFloat(_this.getProfit());
        return !isNaN(profit) && profit >= 0;
    };

    _this.formatProfitLabel = function () {
        var profit = parseFloat(_this.getProfit());
        if (isNaN(profit)) return '';
        var template = profit >= 0
            ? (window._mtRateProfitPositivePhrase || '{amount}-ით მეტია')
            : (window._mtRateProfitNegativePhrase || '{amount}-ით ნაკლებია');
        return template.replace('{amount}', _this.formatGelAmount(Math.abs(profit).toFixed(2)));
    };

    _this.getStandardRate = function () {
        var r = getRate();
        if (!r) return '';
        return '1 ' + r.Currency + ' = ' + parseFloat(r.CommercialSell).toFixed(3) + ' GEL';
    };

    _this.getMtRate = function () {
        var r = getRate();
        if (!r) return '';
        return '1 ' + r.Currency + ' = ' + parseFloat(r.MTRateBuy).toFixed(3) + ' GEL';
    };

    _this.formatGelAmount = function (val) {
        if (val == null) return '';
        return parseFloat(val)
            .toLocaleString('en-us', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
            .replace(/,/g, ' ') + ' ₾';
    };
}]);

